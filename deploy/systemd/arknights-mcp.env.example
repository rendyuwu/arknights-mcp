# EnvironmentFile for the arknights-mcp systemd unit (§V12/§I.env; §T55).
#
# Copy to /etc/arknights-mcp/arknights-mcp.env, fill in real values, then:
#   sudo chown root:root /etc/arknights-mcp/arknights-mcp.env
#   sudo chmod 600 /etc/arknights-mcp/arknights-mcp.env
#
# Secrets and non-secret OIDC descriptors are supplied via the environment only,
# NEVER committed to git or baked into config.toml (§V12/§I.env). These three
# descriptors overlay the [auth] block at startup (config.serve overrides). The
# server refuses to start if the remote posture is unsafe (§V9/§V40): a
# behind_proxy or non-loopback bind without HTTPS + valid OIDC fails closed.

# OIDC issuer (exact match incl. trailing slash, §V10). Example (Auth0):
ARKNIGHTS_MCP_OIDC_ISSUER=https://your-tenant.example.auth0.com/

# The MCP resource-server audience this deployment accepts (§V10).
ARKNIGHTS_MCP_OIDC_AUDIENCE=https://mcp.example.com

# JWKS endpoint used to fetch signing keys by `kid` (§V10). Usually the issuer's
# .well-known/jwks.json.
ARKNIGHTS_MCP_OIDC_JWKS_URL=https://your-tenant.example.auth0.com/.well-known/jwks.json
