# env_file for the docker-compose `mcp` service (§V12/§I.env; §T55).
#
# Copy to arknights-mcp.env in this directory and fill in real values. Keep it
# out of git -- secrets and OIDC descriptors are env-only, never committed
# (§V12/§I.env). The .gitignore already excludes .env / .env.* at the repo root;
# this file is the template only.
#
# These three descriptors overlay the [auth] block at startup. The server
# refuses to start if the remote posture is unsafe (§V9/§V40): behind_proxy set
# without HTTPS + valid OIDC fails closed.

# OIDC issuer (exact match incl. trailing slash, §V10).
ARKNIGHTS_MCP_OIDC_ISSUER=https://your-tenant.example.auth0.com/

# The MCP resource-server audience this deployment accepts (§V10).
ARKNIGHTS_MCP_OIDC_AUDIENCE=https://mcp.example.com

# JWKS endpoint used to fetch signing keys by `kid` (§V10).
ARKNIGHTS_MCP_OIDC_JWKS_URL=https://your-tenant.example.auth0.com/.well-known/jwks.json
